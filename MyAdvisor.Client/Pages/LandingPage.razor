@page "/"

<div class="min-h-screen bg-white flex flex-col">
    <nav class="flex items-center justify-between px-8 py-4 border-b border-gray-200">
        <span class="text-xl font-semibold text-gray-900">MyAdvisor</span>
        <div class="flex gap-3">
            <a href="/login" class="px-4 py-2 text-sm text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Log in</a>
            <a href="/register" class="px-4 py-2 text-sm text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-colors">Get started</a>
        </div>
    </nav>

    <main class="flex flex-col items-center text-center px-6 pt-24 pb-16 flex-1">
        <h1 class="text-5xl font-bold text-gray-900 leading-tight max-w-2xl">
            Take control of your personal finances
        </h1>
        <p class="mt-6 text-lg text-gray-500 max-w-xl">
            Track spending, set budgets, and get AI-powered insights — all in one place.
        </p>
        <div class="mt-10 flex gap-4">
            <a href="/register" class="px-6 py-3 text-white bg-indigo-600 rounded-lg font-medium hover:bg-indigo-700 transition-colors">Start for free</a>
            <a href="#features" class="px-6 py-3 text-gray-700 border border-gray-300 rounded-lg font-medium hover:bg-gray-50 transition-colors">Learn more</a>
        </div>
    </main>

    <section id="features" class="bg-gray-50 py-20 px-6">
        <h2 class="text-center text-3xl font-bold text-gray-900 mb-12">Everything you need</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
                <div class="text-3xl mb-4">📒</div>
                <h3 class="font-semibold text-gray-900 mb-2">Financial Diary</h3>
                <p class="text-sm text-gray-500">Log every purchase manually and keep a clear record of your daily spending.</p>
            </div>
            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
                <div class="text-3xl mb-4">📊</div>
                <h3 class="font-semibold text-gray-900 mb-2">Statistics</h3>
                <p class="text-sm text-gray-500">Visualize your spending over time with easy-to-read charts and breakdowns.</p>
            </div>
            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
                <div class="text-3xl mb-4">🤖</div>
                <h3 class="font-semibold text-gray-900 mb-2">AI Assistant</h3>
                <p class="text-sm text-gray-500">Get personalized advice and spending insights from your AI financial advisor.</p>
            </div>
        </div>
    </section>

    <footer class="text-center py-6 text-sm text-gray-400 border-t border-gray-200">
        © @DateTime.Now.Year MyAdvisor. All rights reserved.
    </footer>
</div>
