@page "/register"
@inject AuthService AuthService
@inject NavigationManager Nav

<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4">
    <div class="w-full max-w-sm bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
        <h1 class="text-2xl font-bold text-gray-900 mb-1">Create an account</h1>
        <p class="text-sm text-gray-500 mb-8">Start managing your finances today</p>

        <EditForm Model="model" OnValidSubmit="HandleSubmit" class="flex flex-col gap-4">
            <div class="flex gap-3 min-w-0">
                <div class="flex flex-col gap-1 min-w-0 flex-1">
                    <label class="text-sm font-medium text-gray-700">First name</label>
                    <InputText @bind-Value="model.FirstName" placeholder="John"
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" />
                </div>
                <div class="flex flex-col gap-1 min-w-0 flex-1">
                    <label class="text-sm font-medium text-gray-700">Last name</label>
                    <InputText @bind-Value="model.LastName" placeholder="Doe"
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" />
                </div>
            </div>

            <div class="flex flex-col gap-1">
                <label class="text-sm font-medium text-gray-700">Email</label>
                <InputText @bind-Value="model.Email" type="email" placeholder="you@example.com"
                    class="px-3 py-2 border border-gray-300 rounded-lg text-sm outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" />
            </div>

            <div class="flex flex-col gap-1">
                <label class="text-sm font-medium text-gray-700">Password</label>
                <InputText @bind-Value="model.Password" type="password" placeholder="••••••••"
                    class="px-3 py-2 border border-gray-300 rounded-lg text-sm outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" />
            </div>

            <div class="flex flex-col gap-1">
                <label class="text-sm font-medium text-gray-700">Confirm password</label>
                <InputText @bind-Value="model.Confirm" type="password" placeholder="••••••••"
                    class="px-3 py-2 border border-gray-300 rounded-lg text-sm outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" />
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <p class="text-sm text-red-500">@error</p>
            }

            <button type="submit" disabled="@loading"
                class="mt-2 w-full py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors disabled:opacity-60">
                @(loading ? "Creating account..." : "Create account")
            </button>
        </EditForm>

        <p class="mt-6 text-center text-sm text-gray-500">
            Already have an account?
            <a href="/login" class="text-indigo-600 font-medium hover:underline">Log in</a>
        </p>
    </div>
</div>

@code {
    private RegisterModel model = new();
    private string error = "";
    private bool loading;

    private async Task HandleSubmit()
    {
        if (model.Password != model.Confirm)
        {
            error = "Passwords do not match";
            return;
        }
        error = "";
        loading = true;
        try
        {
            await AuthService.RegisterAsync(model.FirstName, model.LastName, model.Email, model.Password);
            Nav.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private class RegisterModel
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string Confirm { get; set; } = "";
    }
}
