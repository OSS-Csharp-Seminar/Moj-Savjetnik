@page "/demo"
@inject NavigationManager Nav
@inject AuthService AuthService

<nav class="bg-white border-b border-[#E5E7EB] px-8 py-4 flex items-center justify-between">
    <span class="text-xl font-semibold text-gray-900">MyAdvisor</span>
    <div class="flex items-center gap-4">
        <a href="/diary" class="text-sm text-gray-500 hover:text-gray-700 transition-colors">Diary</a>
        <a href="/chat" class="text-sm text-gray-500 hover:text-gray-700 transition-colors">AI Advisor</a>
    </div>
</nav>

<main class="max-w-4xl mx-auto px-4 py-10">

    <div class="text-center mb-12">
        <h1 class="text-3xl font-bold text-gray-900 mb-3">MyAdvisor Feature Demo</h1>
        <p class="text-gray-500 text-sm max-w-xl mx-auto">A walkthrough of every AI-powered feature built into the app. Click any step to try it live.</p>
    </div>

    <div class="flex flex-col gap-6">

        <!-- Feature 1: AI Import -->
        <div class="bg-white border border-[#E5E7EB] rounded-2xl shadow-sm overflow-hidden">
            <div class="flex items-start gap-5 p-6">
                <div class="w-12 h-12 rounded-xl bg-violet-100 flex items-center justify-center text-2xl flex-shrink-0">📷</div>
                <div class="flex-1">
                    <div class="flex items-center gap-3 mb-1">
                        <h2 class="text-base font-semibold text-gray-900">AI Receipt & Statement Import</h2>
                        <span class="text-xs font-medium px-2 py-0.5 bg-violet-100 text-violet-700 rounded-full">Core Feature</span>
                    </div>
                    <p class="text-sm text-gray-500 mb-4">
                        Upload a photo of a receipt, bank statement, or expense list. Gemini AI reads it, extracts every transaction,
                        and presents them for your review before saving anything to the database.
                    </p>
                    <div class="bg-gray-50 rounded-xl p-4 mb-4 text-sm text-gray-600 flex flex-col gap-2">
                        <div class="flex items-start gap-2">
                            <span class="text-violet-500 font-bold mt-0.5">1</span>
                            <span>Open the <strong>Financial Diary</strong> page and expand or create a diary entry</span>
                        </div>
                        <div class="flex items-start gap-2">
                            <span class="text-violet-500 font-bold mt-0.5">2</span>
                            <span>Click <strong>📷 AI Import</strong> on any diary card and select an image</span>
                        </div>
                        <div class="flex items-start gap-2">
                            <span class="text-violet-500 font-bold mt-0.5">3</span>
                            <span>Review the extracted transactions — uncheck any you don't want</span>
                        </div>
                        <div class="flex items-start gap-2">
                            <span class="text-violet-500 font-bold mt-0.5">4</span>
                            <span>If Gemini suggests a new category not in your list, you can approve or reject it</span>
                        </div>
                        <div class="flex items-start gap-2">
                            <span class="text-violet-500 font-bold mt-0.5">5</span>
                            <span>Click <strong>Import</strong> — transactions and any approved categories are saved instantly</span>
                        </div>
                    </div>
                    <button @onclick='() => Nav.NavigateTo("/diary")'
                        class="px-4 py-2 bg-violet-700 text-white text-sm font-medium rounded-lg hover:bg-violet-800 transition-colors">
                        Try it → Go to Diary
                    </button>
                </div>
            </div>
        </div>

        <!-- Feature 2: Category Suggestions -->
        <div class="bg-white border border-[#E5E7EB] rounded-2xl shadow-sm overflow-hidden">
            <div class="flex items-start gap-5 p-6">
                <div class="w-12 h-12 rounded-xl bg-emerald-100 flex items-center justify-center text-2xl flex-shrink-0">🏷️</div>
                <div class="flex-1">
                    <div class="flex items-center gap-3 mb-1">
                        <h2 class="text-base font-semibold text-gray-900">Smart Category Suggestions</h2>
                        <span class="text-xs font-medium px-2 py-0.5 bg-emerald-100 text-emerald-700 rounded-full">AI Powered</span>
                    </div>
                    <p class="text-sm text-gray-500 mb-4">
                        When Gemini reads a transaction it can't fit into an existing category, it suggests a new one.
                        You see exactly which categories are new (highlighted in purple) and decide whether to create them.
                        Nothing is created without your approval.
                    </p>
                    <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-4 text-sm text-emerald-800">
                        <p class="font-semibold mb-1">Example</p>
                        <p>You upload a receipt from a veterinary clinic. Your existing categories are Food, Transport, Entertainment.
                        Gemini suggests <strong>"Pet Care"</strong> as a new category. You can approve it once and it's available for all future transactions.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Feature 3: Receipt Summarization -->
        <div class="bg-white border border-[#E5E7EB] rounded-2xl shadow-sm overflow-hidden">
            <div class="flex items-start gap-5 p-6">
                <div class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center text-2xl flex-shrink-0">🔍</div>
                <div class="flex-1">
                    <div class="flex items-center gap-3 mb-1">
                        <h2 class="text-base font-semibold text-gray-900">Receipt & Document Summarization</h2>
                        <span class="text-xs font-medium px-2 py-0.5 bg-blue-100 text-blue-700 rounded-full">AI Chat</span>
                    </div>
                    <p class="text-sm text-gray-500 mb-4">
                        Upload any financial document directly in the AI chat. Gemini reads it and gives you a structured
                        financial summary — merchant, amounts, date, payment method, and observations — without importing
                        anything into the diary. Great for a quick understanding of a document.
                    </p>
                    <div class="bg-gray-50 rounded-xl p-4 mb-4 text-sm text-gray-600 flex flex-col gap-2">
                        <div class="flex items-start gap-2">
                            <span class="text-blue-500 font-bold mt-0.5">1</span>
                            <span>Open the <strong>AI Advisor</strong> chat page</span>
                        </div>
                        <div class="flex items-start gap-2">
                            <span class="text-blue-500 font-bold mt-0.5">2</span>
                            <span>Click the <strong>📷 camera button</strong> next to the text input</span>
                        </div>
                        <div class="flex items-start gap-2">
                            <span class="text-blue-500 font-bold mt-0.5">3</span>
                            <span>Select a photo of a receipt, invoice, or bank statement</span>
                        </div>
                        <div class="flex items-start gap-2">
                            <span class="text-blue-500 font-bold mt-0.5">4</span>
                            <span>Gemini returns a structured breakdown of the document in seconds</span>
                        </div>
                    </div>
                    <button @onclick='() => Nav.NavigateTo("/chat")'
                        class="px-4 py-2 bg-blue-700 text-white text-sm font-medium rounded-lg hover:bg-blue-800 transition-colors">
                        Try it → Open AI Chat
                    </button>
                </div>
            </div>
        </div>

        <!-- Feature 4: Financial Analyst Chatbot -->
        <div class="bg-white border border-[#E5E7EB] rounded-2xl shadow-sm overflow-hidden">
            <div class="flex items-start gap-5 p-6">
                <div class="w-12 h-12 rounded-xl bg-amber-100 flex items-center justify-center text-2xl flex-shrink-0">💬</div>
                <div class="flex-1">
                    <div class="flex items-center gap-3 mb-1">
                        <h2 class="text-base font-semibold text-gray-900">Personalized Financial Analyst</h2>
                        <span class="text-xs font-medium px-2 py-0.5 bg-amber-100 text-amber-700 rounded-full">AI Chat</span>
                    </div>
                    <p class="text-sm text-gray-500 mb-4">
                        Chat with an AI that knows your actual spending. With <strong>"Include my transactions"</strong> turned on,
                        Gemini gets a full summary of your diary — totals, spending by category, and recent transactions —
                        so it can give advice tailored to you, not generic tips.
                    </p>

                    <div class="grid grid-cols-2 gap-3 mb-4">
                        <div class="bg-amber-50 border border-amber-200 rounded-xl p-3">
                            <p class="text-xs font-semibold text-amber-800 mb-1">With transactions ON</p>
                            <p class="text-xs text-amber-700">"You spent 45% of your expenses on Food last month — that's above average. Consider a weekly food budget."</p>
                        </div>
                        <div class="bg-gray-50 border border-[#E5E7EB] rounded-xl p-3">
                            <p class="text-xs font-semibold text-gray-700 mb-1">General mode (OFF)</p>
                            <p class="text-xs text-gray-600">"A good rule of thumb is to keep food costs under 15% of your monthly income..."</p>
                        </div>
                    </div>

                    <div class="bg-gray-50 rounded-xl p-4 mb-4">
                        <p class="text-xs font-semibold text-gray-700 mb-2">Sample questions to try:</p>
                        <ul class="text-xs text-gray-600 flex flex-col gap-1">
                            <li>• "Summarize my spending and tell me where I'm overspending"</li>
                            <li>• "What's a realistic savings goal for my income level?"</li>
                            <li>• "Explain the 50/30/20 budgeting rule and how it applies to me"</li>
                            <li>• "What categories should I cut first to save €200 per month?"</li>
                        </ul>
                    </div>

                    <button @onclick='() => Nav.NavigateTo("/chat")'
                        class="px-4 py-2 bg-amber-600 text-white text-sm font-medium rounded-lg hover:bg-amber-700 transition-colors">
                        Try it → Open AI Advisor
                    </button>
                </div>
            </div>
        </div>

        <!-- Flow diagram -->
        <div class="bg-white border border-[#E5E7EB] rounded-2xl shadow-sm p-6">
            <h2 class="text-base font-semibold text-gray-900 mb-4">How it all fits together</h2>
            <div class="flex items-center gap-2 flex-wrap">
                <div class="bg-slate-900 text-white text-xs font-medium px-3 py-2 rounded-lg">Upload image</div>
                <span class="text-gray-400 text-sm">→</span>
                <div class="bg-violet-100 text-violet-800 text-xs font-medium px-3 py-2 rounded-lg">Gemini reads it</div>
                <span class="text-gray-400 text-sm">→</span>
                <div class="bg-emerald-100 text-emerald-800 text-xs font-medium px-3 py-2 rounded-lg">You review & approve</div>
                <span class="text-gray-400 text-sm">→</span>
                <div class="bg-blue-100 text-blue-800 text-xs font-medium px-3 py-2 rounded-lg">Saved to diary</div>
                <span class="text-gray-400 text-sm">→</span>
                <div class="bg-amber-100 text-amber-800 text-xs font-medium px-3 py-2 rounded-lg">AI advisor uses your data</div>
            </div>
            <p class="text-xs text-gray-400 mt-4">
                All AI features use <strong>Gemini 2.5 Flash</strong> via the Google AI free tier. No transaction data is ever sent to third parties beyond what you explicitly upload for analysis.
            </p>
        </div>

    </div>
</main>

@code {
    protected override async Task OnInitializedAsync()
    {
        if (!await AuthService.IsAuthenticatedAsync())
            Nav.NavigateTo("/login");
    }
}
